# Copy this file to .env.sync_quantum_wo on the bridge PC and fill real values.
# This WO preview script only reads Quantum and writes local CSV/XLS files.

# Oracle Instant Client / Quantum connection.
ORACLE_CLIENT_DIR=C:\oracle
TNS_ADMIN=C:\oracle
ORACLE_USER=CHANGE_ME
ORACLE_PASS=CHANGE_ME
ORACLE_DSN=MAXQPROD

# PHP bundled with the bridge package.
PHP_PATH=C:\avia\WO\PHP_8.1\php.exe

# Local script timezone.
AVIA_SYNC_TIMEZONE=America/Toronto
