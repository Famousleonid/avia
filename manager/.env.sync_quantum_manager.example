# Copy this file to .env.sync_quantum_manager on the bridge PC and fill real values.
# Manager sync only reads Quantum and writes local CSV/XLS diagnostic files.

# Oracle Instant Client / Quantum connection.
ORACLE_CLIENT_DIR=C:\oracle
TNS_ADMIN=C:\oracle

# Manager-specific variables are preferred by manager/sync_manager.php.
QUANTUM_MANAGER_ORACLE_USER=CHANGE_ME
QUANTUM_MANAGER_ORACLE_PASS=CHANGE_ME
QUANTUM_MANAGER_ORACLE_DSN=MAXQPROD

# Fallback shared variables are also supported:
# ORACLE_USER=CHANGE_ME
# ORACLE_PASS=CHANGE_ME
# ORACLE_DSN=MAXQPROD

# PHP bundled with the bridge package.
PHP_PATH=C:\avia\manager\PHP_8.1\php.exe

# Local script timezone.
AVIA_SYNC_TIMEZONE=America/Toronto
