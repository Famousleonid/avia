# Copy this file to .env.sync_quantum on the bridge PC and fill real values.
# The scheduled task loads this file only for the sync_quantum process.

# Oracle Instant Client / Quantum connection.
ORACLE_CLIENT_DIR=C:\oracle
TNS_ADMIN=C:\oracle
ORACLE_USER=CHANGE_ME
ORACLE_PASS=CHANGE_ME
ORACLE_DSN=MAXQPROD

# PHP bundled with the bridge package.
PHP_PATH=C:\avia\RO\PHP_8.1\php.exe

# Hosted avia API.
AVIA_SYNC_API_URL=https://your-host.example/api/quantum/ro-sync
AVIA_SYNC_API_TOKEN=CHANGE_ME
AVIA_SYNC_TIMEZONE=America/Toronto
