APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=America/Toronto

# Laravel Debugbar (dev). false — отключить панель и assets/_debugbar на всех страницах.
DEBUGBAR_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Full DB backup (mysqldump). On Windows OSPanel set full paths if not in PATH, e.g. MySQL:
# BACKUP_MYSQLDUMP_PATH=C:\OSPanel\modules\database\MySQL-8.0-Win10\bin\mysqldump.exe
# BACKUP_MYSQL_PATH=C:\OSPanel\modules\database\MySQL-8.0-Win10\bin\mysql.exe
# (Or MySQL-5.7-Win10, etc. — match the MySQL version you use in OSPanel.)
BACKUP_MYSQLDUMP_PATH=
BACKUP_MYSQL_PATH=
BACKUP_KEEP_DAYS=14

# Activity log retention (days). Older records are deleted by scheduler (activitylog:clean).
ACTIVITY_LOG_RETENTION_DAYS=365

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
